{
    "name": "palimper/palimper-3x3",
    "description": "FIBA 3x3 basketball tournament management WordPress plugin.",
    "type": "wordpress-plugin",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Palimper\\ThreeXThree\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Palimper\\ThreeXThree\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
